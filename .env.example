HOOP_CENTRAL_API_URL=http://localhost:3001
# Optional — send x-ingest-api-key when set
# INGEST_API_KEY=

# Delay between BRef player page requests (ms). Backfill default: 6000 (~9h full run).
# SCRAPE_REQUEST_DELAY_MS=6000

# Delay between A–Z index letter pages during backfill (ms). Default: 10000.
# SCRAPE_INDEX_DELAY_MS=10000
